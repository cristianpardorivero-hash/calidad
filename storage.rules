rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isEditor() {
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }

    function getHospitalId() {
       return get(/databases/(default)/documents/users/$(request.auth.uid)).data.hospitalId;
    }

    match /documentos/{hid}/{allPaths=**} {
      // Temporarily simplify read access as well for debugging
      allow read: if request.auth != null && hid == getHospitalId();

      // The simplified create rule for debugging
      allow create: if isEditor() && hid == getHospitalId();
        
      allow update, delete: if false;
    }
  }
}
