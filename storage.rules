rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // WARNING: TEMPORARY DEBUGGING RULES
    // These rules are insecure and are for diagnostic purposes only.
    match /documentos/{hospitalId}/{allPaths=**} {
      
      // Temporarily allow any authenticated user to read.
      allow read: if request.auth != null;

      // Temporarily allow any authenticated user to write, only checking file size and type.
      // This is to test if the Firestore 'get()' call is the source of the error.
      allow create: if request.auth != null &&
                       request.resource.size < 25 * 1024 * 1024 &&
                       (request.resource.contentType == 'application/pdf' ||
                        request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' ||
                        request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
        
      allow update, delete: if false;
    }
  }
}
