rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions to read user data from Firestore
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // Path to the user's profile document in Firestore
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Checks if the user's profile exists and is active
    function isActive() {
      return isSignedIn() && userDocExists() && getUserData().isActive == true;
    }

    // Gets the user's role from their Firestore document
    function getRole() {
      return getUserData().role;
    }

    // Gets the user's hospital ID from their Firestore document
    function getHospitalId() {
      return getUserData().hospitalId;
    }

    // Checks if the user has at least read permissions
    function isReader() {
      return isActive() && getRole() in ['lector', 'editor', 'admin'];
    }
    
    // Checks if the user has write permissions
    function isEditor() {
      return isActive() && getRole() in ['editor', 'admin'];
    }

    // Validates the content type of the uploaded file
    function isAllowedContentType() {
      return request.resource.contentType == "application/pdf"
        || request.resource.contentType == "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
        || request.resource.contentType == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
    }

    // Validates the file size (e.g., max 25MB)
    function isUnderMaxSize() {
      return request.resource.size < 25 * 1024 * 1024;
    }

    // Match the path where documents are stored: /documentos/{hospitalId}/...
    match /documentos/{hid}/{allPaths=**} {

      // READ access is granted if the user is a reader and belongs to the hospital (`hid`) specified in the path.
      allow read: if isReader() && hid == getHospitalId();

      // CREATE (upload) access is granted if the user is an editor/admin, belongs to the correct hospital,
      // and the file meets content type and size constraints.
      allow create: if isEditor()
        && hid == getHospitalId()
        && isAllowedContentType()
        && isUnderMaxSize();
        
      // UPDATE and DELETE are disallowed from the client to protect file integrity.
      // File changes should be handled as new uploads/versions.
      allow update, delete: if false;
    }
  }
}
