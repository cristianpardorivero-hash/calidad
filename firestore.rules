/**
 * Core Philosophy:
 * This ruleset enforces a strict multi-tenant security model for a hospital document
 * management system. All data is scoped by a `hospitalId`. A user's access is
 * primarily determined by their assigned `hospitalId` and `role` (admin, editor, lector),
 * which are stored on their user profile document.
 *
 * Data Structure:
 * The data is organized into top-level collections for major entities like `users`,
 * `hospitals`, and `documents`. Hospital-specific configuration data (catalogs) is
 * nested under a `/catalogs/{hospitalId}` path, providing clear structural
 * segregation for each tenant's data.
 *
 * Key Security Decisions:
 * - Denormalization for Authorization: To ensure fast and secure rule evaluation,
 *   the `hospitalId` is denormalized onto every relevant document. This avoids
 *   slow and costly cross-document `get()` calls during authorization checks.
 * - Centralized User Context: Rules frequently perform a single `get()` on the
 *   requesting user's own `/users/{userId}` document to retrieve their `hospitalId`
 *   and `role`. This context is then used to evaluate permissions across the database.
 * - Role-Based Access: Write permissions (create, update, delete) are generally
 *   restricted to users with 'admin' or 'editor' roles within their hospital,
 *   while read access is granted to all members ('lector' included).
 * - No User Listing: To protect user privacy and prevent data leakage, listing
 *   the entire `/users` collection is explicitly forbidden unless you are an admin.
 * - Immutable Logs: Audit logs are append-only. Once created, they cannot be
 *   modified or deleted, ensuring the integrity of the audit trail.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * Used to verify resource ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Retrieves the requesting user's profile data from /users/{uid}.
     * This is the central function for fetching a user's role and hospitalId,
     * which are then used for permission checks throughout the rules.
     * The result is automatically cached by Firestore for the duration of the
     * request evaluation, so it's efficient to call multiple times.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Checks if the user is a member of the specified hospital.
     */
    function isHospitalMember(hospitalId) {
      return isSignedIn() && getUserData().hospitalId == hospitalId;
    }

    /**
     * Checks if the user has editor or admin privileges for the specified hospital.
     */
    function isHospitalEditor(hospitalId) {
      return isHospitalMember(hospitalId) && getUserData().role in ['admin', 'editor'];
    }

    /**
     * Checks if the user has admin privileges for the specified hospital.
     */
    function isHospitalAdmin(hospitalId) {
      return isHospitalMember(hospitalId) && getUserData().role == 'admin';
    }

    /**
     * Validates that the hospitalId in a document being created matches its
     * location in the path, ensuring relational integrity.
     */
    function hasMatchingHospitalIdInPath(hospitalId) {
      return request.resource.data.hospitalId == hospitalId;
    }
    
    /**
     * Validates that the hospitalId on a newly created document matches the
     * hospitalId of the user creating it.
     */
    function hospitalIdMatchesCreator() {
      return request.resource.data.hospitalId == getUserData().hospitalId;
    }
    
    /**
     * Validates that the creator of a resource is the currently authenticated user.
     * This is used on create operations for documents, versions, and logs.
     */
    function creatorIsSelf() {
      // Use 'createdByUid' for documents, 'actorUid' for logs.
      let ownerField = 'createdByUid' in request.resource.data ? request.resource.data.createdByUid : request.resource.data.actorUid;
      return ownerField == request.auth.uid;
    }

    /**
     * Enforces the immutability of critical relational fields during an update.
     */
    function isImmutable(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // =====================================================================
    // User Profiles
    // =====================================================================

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get) Any authenticated user, to allow cross-service rules (like Storage) to verify permissions.
     * @allow (list) A hospital admin to list profiles of users within their own hospital.
     * @principle Restricts access to a user's own data tree and allows for admin oversight.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isHospitalAdmin(getUserData().hospitalId);
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isHospitalAdmin(request.resource.data.hospitalId);
      allow update: if resource != null && (isOwner(userId) || isHospitalAdmin(resource.data.hospitalId)) && isImmutable('id');
      allow delete: if resource != null && (isOwner(userId) || isHospitalAdmin(resource.data.hospitalId));
    }

    // =====================================================================
    // Hospital Data
    // =====================================================================

    /**
     * @description Controls access to general hospital information.
     * @path /hospitals/{hospitalId}
     * @allow (get) An authenticated user who is a member of the hospital to read its details.
     * @deny (create) Any user from creating a new hospital document from the client.
     * @principle Enforces tenant isolation; data is only visible to members of that tenant.
     */
    match /hospitals/{hospitalId} {
      allow get: if isHospitalMember(hospitalId);
      allow list: if isSignedIn(); // Client MUST filter by the user's hospitalId for security.
      allow create: if isHospitalAdmin(hospitalId);
      allow update: if resource != null && isHospitalAdmin(hospitalId);
      allow delete: if false;
    }

    // =====================================================================
    // Catalog Subcollections
    // All catalog collections share the same security rules logic.
    // =====================================================================

    /**
     * @description Controls access to hospital-specific 'Ambito' (Scope) catalog items.
     * @path /catalogs/{hospitalId}/ambitos/{ambitoId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/ambitos/{ambitoId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    /**
     * @description Controls access to hospital-specific 'Caracteristica' (Characteristic) items.
     * @path /catalogs/{hospitalId}/caracteristicas/{caracteristicaId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/caracteristicas/{caracteristicaId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    /**
     * @description Controls access to hospital-specific 'Elemento Medible' (Measurable Element) items.
     * @path /catalogs/{hospitalId}/elementosMedibles/{elementoMedibleId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/elementosMedibles/{elementoMedibleId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    /**
     * @description Controls access to hospital-specific 'Tipo de Documento' (Document Type) items.
     * @path /catalogs/{hospitalId}/tiposDocumento/{tipoDocumentoId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/tiposDocumento/{tipoDocumentoId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    /**
     * @description Controls access to hospital-specific 'Servicio' (Service/Unit) items.
     * @path /catalogs/{hospitalId}/servicios/{servicioId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/servicios/{servicioId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    /**
     * @description Controls access to hospital-specific 'Estado de Acreditación' (Accreditation Status) items.
     * @path /catalogs/{hospitalId}/estadosAcreditacionDoc/{estadoAcreditacionDocId}
     * @allow (read) Any user who belongs to the hospital specified in the path.
     * @deny (write) A 'lector' (reader) role from modifying catalog items.
     * @principle Inherits permissions from the parent hospital path, enforcing tenant isolation.
     */
    match /catalogs/{hospitalId}/estadosAcreditacionDoc/{estadoAcreditacionDocId} {
      allow get, list: if isHospitalMember(hospitalId);
      allow create: if isHospitalEditor(hospitalId) && hasMatchingHospitalIdInPath(hospitalId);
      allow update: if resource != null && isHospitalEditor(hospitalId) && isImmutable('hospitalId');
      allow delete: if resource != null && isHospitalEditor(hospitalId);
    }

    // =====================================================================
    // Documents
    // =====================================================================

    /**
     * @description Controls access to document metadata. Access is granted based on the
     * `hospitalId` field denormalized onto each document.
     * @path /documents/{documentId}
     * @allow (get) A user to read a document if they belong to the document's hospital.
     * @allow (create) An 'editor' or 'admin' to create a document for their own hospital.
     * @deny (get) A user from Hospital B from reading a document belonging to Hospital A.
     * @principle Enforces tenant isolation using a denormalized field on the document itself.
     */
    match /documents/{documentId} {
      allow get: if isHospitalMember(resource.data.hospitalId);
      allow list: if isSignedIn(); // Client MUST filter by the user's hospitalId for security.
      allow create: if isHospitalEditor(request.resource.data.hospitalId) && creatorIsSelf() && hospitalIdMatchesCreator();
      allow update: if resource != null && isHospitalEditor(resource.data.hospitalId) && isImmutable('hospitalId') && isImmutable('createdByUid');
      allow delete: if resource != null && isHospitalEditor(resource.data.hospitalId);
    }

    // =====================================================================
    // Document Versions
    // =====================================================================

    /**
     * @description Controls access to historical versions of documents. These are append-only.
     * @path /document_versions/{documentVersionId}
     * @allow (get) A user to read a document version if they belong to its hospital.
     * @deny (update, delete) Any user from modifying or deleting historical version records.
     * @principle Provides read-only access to historical data while ensuring its immutability.
     */
    match /document_versions/{documentVersionId} {
      allow get: if isHospitalMember(resource.data.hospitalId);
      allow list: if isSignedIn(); // Client MUST filter by the user's hospitalId for security.
      allow create: if isHospitalEditor(request.resource.data.hospitalId) && request.resource.data.archivedByUid == request.auth.uid && hospitalIdMatchesCreator();
      allow update: if false;
      allow delete: if false;
    }

    // =====================================================================
    // Audit Logs
    // =====================================================================

    /**
     * @description Controls access to audit logs. Logs are append-only and can only
     * be read by hospital administrators.
     * @path /audit_logs/{auditLogId}
     * @allow (create) Any authenticated user to create a log entry for their own actions and hospital.
     * @deny (read) A non-admin user from reading any audit log entries.
     * @deny (update, delete) Any user from modifying or deleting an audit log entry.
     * @principle Ensures the integrity and confidentiality of the audit trail.
     */
    match /audit_logs/{auditLogId} {
      allow get: if isHospitalAdmin(resource.data.hospitalId);
      allow list: if isSignedIn(); // Client MUST filter by hospitalId. Admin UI should enforce this.
      allow create: if isHospitalMember(request.resource.data.hospitalId) && creatorIsSelf() && hospitalIdMatchesCreator();
      allow update: if false;
      allow delete: if false;
    }
  }
}
